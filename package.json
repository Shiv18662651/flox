{
  "name": "nexify",
  "version": "1.0.0",
  "description": "Nexify - All-in-one Shopify Super-App",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "remix vite:build",
    "dev": "remix vite:dev",
    "start": "remix-serve ./build/server/index.js",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "typecheck": "tsc --noEmit",
    "shopify": "shopify",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "keywords": [
    "shopify",
    "remix",
    "ecommerce"
  ],
  "author": "",
  "license": "UNLICENSED",
  "devDependencies": {
    "@remix-run/dev": "^2.17.4",
    "@remix-run/node": "^2.17.4",
    "@remix-run/react": "^2.17.4",
    "@shopify/app": "^3.58.2",
    "@shopify/cli": "^3.94.3",
    "@shopify/shopify-app-remix": "^4.2.0",
    "@shopify/shopify-app-session-storage-prisma": "^9.0.0",
    "@types/node": "^25.6.2",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.5",
    "fast-check": "^4.7.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@shopify/polaris": "^13.9.5",
    "dotenv": "^16.5.0",
    "tsx": "^4.19.4",
    "bullmq": "^5.76.6",
    "groq-sdk": "^1.1.2",
    "ioredis": "^5.10.1",
    "isbot": "^5.1.40",
    "meilisearch": "^0.58.0",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "socket.io": "^4.8.3"
  }
}
