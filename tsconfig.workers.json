{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "outDir": "workers/dist",
    "rootDir": "workers",
    "noEmit": false,
    "declaration": false,
    "sourceMap": true
  },
  "include": ["workers/**/*.ts"],
  "exclude": ["workers/**/*.test.ts", "node_modules"]
}
