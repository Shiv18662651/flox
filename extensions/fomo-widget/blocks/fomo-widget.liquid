<div
  id="nexify-fomo"
  class="nexify-fomo"
  data-app-url="{{ block.settings.app_url }}"
  data-shop-id="{{ block.settings.shop_id }}"
  data-product-id="{% if product %}{{ product.id }}{% endif %}"
>
  <div class="nexify-fomo__popup" id="nexify-fomo-popup" aria-live="polite" role="alert">
    <button class="nexify-fomo__close" id="nexify-fomo-close" aria-label="Dismiss notification">&times;</button>
    <div class="nexify-fomo__icon">🛒</div>
    <div class="nexify-fomo__content">
      <div class="nexify-fomo__buyer" id="nexify-fomo-buyer"></div>
      <div class="nexify-fomo__product" id="nexify-fomo-product"></div>
      <div class="nexify-fomo__time" id="nexify-fomo-time"></div>
    </div>
  </div>
</div>

<style>
  .nexify-fomo {
    position: fixed;
    z-index: 99999;
    pointer-events: none;
  }

  .nexify-fomo--bottom-left {
    bottom: 20px;
    left: 20px;
  }

  .nexify-fomo--bottom-right {
    bottom: 20px;
    right: 20px;
  }

  .nexify-fomo__popup {
    position: relative;
    display: none;
    align-items: flex-start;
    gap: 0.75rem;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 1rem 2.5rem 1rem 1rem;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1), 0 4px 10px rgba(0, 0, 0, 0.05);
    max-width: 320px;
    min-width: 260px;
    pointer-events: auto;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  .nexify-fomo__popup--visible {
    display: flex;
    opacity: 1;
    transform: translateY(0);
  }

  .nexify-fomo__popup--hiding {
    opacity: 0;
    transform: translateY(20px);
  }

  .nexify-fomo__close {
    position: absolute;
    top: 0.5rem;
    right: 0.75rem;
    background: none;
    border: none;
    font-size: 1.25rem;
    color: #9ca3af;
    cursor: pointer;
    line-height: 1;
    padding: 0.25rem;
    transition: color 0.15s ease;
  }

  .nexify-fomo__close:hover {
    color: #374151;
  }

  .nexify-fomo__icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .nexify-fomo__content {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .nexify-fomo__buyer {
    font-size: 0.875rem;
    font-weight: 600;
    color: #111827;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .nexify-fomo__product {
    font-size: 0.8125rem;
    color: #374151;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .nexify-fomo__time {
    font-size: 0.75rem;
    color: #9ca3af;
    margin-top: 0.125rem;
  }

  @media (max-width: 480px) {
    .nexify-fomo--bottom-left,
    .nexify-fomo--bottom-right {
      left: 10px;
      right: 10px;
      bottom: 10px;
    }

    .nexify-fomo__popup {
      max-width: 100%;
    }
  }
</style>

<script src="https://cdn.socket.io/4.7.5/socket.io.min.js" crossorigin="anonymous"></script>
{{ 'fomo-widget.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Social Proof Popups",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "app_url",
      "label": "App URL",
      "info": "The URL of your Nexify app (e.g., https://your-app.com)",
      "default": ""
    },
    {
      "type": "text",
      "id": "shop_id",
      "label": "Shop ID",
      "info": "Your Nexify shop ID",
      "default": ""
    }
  ]
}
{% endschema %}
