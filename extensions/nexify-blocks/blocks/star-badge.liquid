{% comment %}
  Nexify Star Rating Badge — App Embed
  Shows mini star rating on product cards, collection pages, etc.
  Target: head
{% endcomment %}

<style>
  .nexify-star-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: inherit;
  }
  .nexify-star-badge__stars {
    display: flex;
    gap: 1px;
    color: #f59e0b;
  }
  .nexify-star-badge__star {
    width: 14px;
    height: 14px;
  }
  .nexify-star-badge__count {
    font-size: 0.8125rem;
    color: #6b7280;
  }
  .nexify-star-badge__count a {
    color: #6b7280;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .nexify-star-badge__count a:hover {
    color: #374151;
  }
</style>

<script>
(function() {
  'use strict';

  var appUrl = '{{ block.settings.app_url | escape }}';
  var shopDomain = '{{ shop.permanent_domain | escape }}';
  var productId = '{% if product %}{{ product.id }}{% endif %}' || null;

  if (!appUrl || !shopDomain || !productId) return;
  appUrl = appUrl.replace(/\/+$/, '');

  // Find all product card links on the page
  var productLinks = document.querySelectorAll('a[href*="/products/"]');
  if (!productLinks.length) return;

  // Build a map of product IDs to their card elements
  var cardMap = {};
  productLinks.forEach(function(link) {
    var href = link.getAttribute('href');
    var match = href.match(/\/products\/([^?]+)/);
    if (match) {
      var handle = match[1];
      // Find the closest product card container
      var card = link.closest('.card, .product-card, [class*="product"], [class*="card"]') || link.parentElement;
      if (!cardMap[handle]) cardMap[handle] = [];
      cardMap[handle].push(card);
    }
  });

  // For single product pages, inject badge near title
  if (window.location.pathname.includes('/products/')) {
    var titleEl = document.querySelector('h1');
    if (titleEl) {
      fetch(appUrl + '/api/reviews/public?shopDomain=' + encodeURIComponent(shopDomain) + '&productId=' + encodeURIComponent(productId) + '&page=1&limit=1')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.totalCount > 0) {
            var badge = createBadge(data.averageRating, data.totalCount);
            titleEl.parentElement.insertBefore(badge, titleEl.nextSibling);
          }
        })
        .catch(function() {});
    }
  }

  function createBadge(avg, count) {
    var div = document.createElement('div');
    div.className = 'nexify-star-badge';
    var starsHtml = '';
    for (var i = 1; i <= 5; i++) {
      var filled = i <= Math.round(avg);
      starsHtml += '<svg class="nexify-star-badge__star" viewBox="0 0 20 20" fill="' + (filled ? 'currentColor' : '#d1d5db') + '"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>';
    }
    div.innerHTML = '<span class="nexify-star-badge__stars">' + starsHtml + '</span>' +
      '<span class="nexify-star-badge__count"><a href="#nexify-reviews">(' + count + ')</a></span>';
    return div;
  }
})();
</script>

{% schema %}
{
  "name": "Star Rating Badge",
  "target": "head",
  "settings": [
    {
      "type": "text",
      "id": "app_url",
      "label": "App URL",
      "info": "The URL of your Nexify app",
      "default": "https://thenexify.app"
    }
  ]
}
{% endschema %}
