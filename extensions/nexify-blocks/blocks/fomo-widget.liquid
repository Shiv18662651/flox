{% comment %}
  Nexify FOMO Widget — App Embed
  Auto-injects on all pages when enabled in the Shopify theme editor.
  Target: head (renders in <head>, injects visible widget into <body> via JS)
{% endcomment %}

<style>
  .nexify-fomo {
    position: fixed;
    z-index: 99999;
    pointer-events: none;
  }

  .nexify-fomo--bottom-left {
    bottom: 20px;
    left: 20px;
  }

  .nexify-fomo--bottom-right {
    bottom: 20px;
    right: 20px;
  }

  .nexify-fomo__popup {
    position: relative;
    display: none;
    align-items: flex-start;
    gap: 0.75rem;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 1rem 2.5rem 1rem 1rem;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1), 0 4px 10px rgba(0, 0, 0, 0.05);
    max-width: 320px;
    min-width: 260px;
    pointer-events: auto;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  .nexify-fomo__popup--visible {
    display: flex;
    opacity: 1;
    transform: translateY(0);
  }

  .nexify-fomo__popup--hiding {
    opacity: 0;
    transform: translateY(20px);
  }

  .nexify-fomo__close {
    position: absolute;
    top: 0.5rem;
    right: 0.75rem;
    background: none;
    border: none;
    font-size: 1.25rem;
    color: #9ca3af;
    cursor: pointer;
    line-height: 1;
    padding: 0.25rem;
    transition: color 0.15s ease;
  }

  .nexify-fomo__close:hover {
    color: #374151;
  }

  .nexify-fomo__icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .nexify-fomo__content {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .nexify-fomo__buyer {
    font-size: 0.875rem;
    font-weight: 600;
    color: #111827;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .nexify-fomo__product {
    font-size: 0.8125rem;
    color: #374151;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .nexify-fomo__time {
    font-size: 0.75rem;
    color: #9ca3af;
    margin-top: 0.125rem;
  }

  @media (max-width: 480px) {
    .nexify-fomo--bottom-left,
    .nexify-fomo--bottom-right {
      left: 10px;
      right: 10px;
      bottom: 10px;
    }

    .nexify-fomo__popup {
      max-width: 100%;
    }
  }
</style>

<script>
  (function () {
    'use strict';

    // Prevent double-injection
    if (document.getElementById('nexify-fomo')) return;

    var appUrl = '{{ block.settings.app_url | escape }}';
    var shopDomain = '{{ shop.permanent_domain | escape }}';
    var productId = '{% if product %}{{ product.id }}{% endif %}' || null;

    if (!appUrl || !shopDomain) return;
    appUrl = appUrl.replace(/\/+$/, '');

    // Create widget container and inject into body when ready
    var container = document.createElement('div');
    container.id = 'nexify-fomo';
    container.className = 'nexify-fomo nexify-fomo--bottom-left';
    container.setAttribute('data-app-url', appUrl);
    container.setAttribute('data-shop-domain', shopDomain);
    if (productId) container.setAttribute('data-product-id', productId);

    function injectFomo() {
      if (document.body) document.body.appendChild(container);
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', injectFomo);
    } else {
      injectFomo();
    }

    container.innerHTML =
      '<div class="nexify-fomo__popup" id="nexify-fomo-popup" aria-live="polite" role="alert">' +
        '<button class="nexify-fomo__close" id="nexify-fomo-close" aria-label="Dismiss notification">&times;</button>' +
        '<div class="nexify-fomo__icon">🛒</div>' +
        '<div class="nexify-fomo__content">' +
          '<div class="nexify-fomo__buyer" id="nexify-fomo-buyer"></div>' +
          '<div class="nexify-fomo__product" id="nexify-fomo-product"></div>' +
          '<div class="nexify-fomo__time" id="nexify-fomo-time"></div>' +
        '</div>' +
      '</div>';

        // Widget state
    var settings = {
      popupPosition: 'bottom-left',
      displayDuration: 5,
      showHistoricalOrders: true,
      historicalInterval: 10
    };
    var popup = document.getElementById('nexify-fomo-popup');
    var closeBtn = document.getElementById('nexify-fomo-close');
    var buyerEl = document.getElementById('nexify-fomo-buyer');
    var productEl = document.getElementById('nexify-fomo-product');
    var timeEl = document.getElementById('nexify-fomo-time');
    var dismissTimer = null;
    var isShowing = false;
    var eventQueue = [];
    var socket = null;
    var pollInterval = null;
    var historicalOrders = [];
    var historicalIndex = 0;
    var historicalTimer = null;
    var usePolling = false;

    function applyPosition() {
      container.className = 'nexify-fomo nexify-fomo--' + settings.popupPosition;
    }

    function relativeTime(timestamp) {
      var now = Date.now();
      var then = new Date(timestamp).getTime();
      var diff = Math.max(0, Math.floor((now - then) / 1000));

      if (diff < 60) return 'just now';
      if (diff < 3600) {
        var mins = Math.floor(diff / 60);
        return mins + (mins === 1 ? ' minute ago' : ' minutes ago');
      }
      if (diff < 86400) {
        var hours = Math.floor(diff / 3600);
        return hours + (hours === 1 ? ' hour ago' : ' hours ago');
      }
      var days = Math.floor(diff / 86400);
      return days + (days === 1 ? ' day ago' : ' days ago');
    }

    function showPopup(event) {
      if (isShowing) {
        eventQueue.push(event);
        return;
      }

      isShowing = true;
      buyerEl.textContent = (event.buyerName || 'Someone') + ' just purchased';
      productEl.textContent = event.productTitle || 'a product';
      timeEl.textContent = relativeTime(event.timestamp);

      popup.style.display = 'flex';
      popup.offsetHeight; // force reflow
      popup.classList.add('nexify-fomo__popup--visible');
      popup.classList.remove('nexify-fomo__popup--hiding');

      clearTimeout(dismissTimer);
      dismissTimer = setTimeout(function () {
        hidePopup();
      }, settings.displayDuration * 1000);
    }

    function hidePopup() {
      popup.classList.add('nexify-fomo__popup--hiding');
      popup.classList.remove('nexify-fomo__popup--visible');

      setTimeout(function () {
        popup.style.display = 'none';
        popup.classList.remove('nexify-fomo__popup--hiding');
        isShowing = false;

        if (eventQueue.length > 0) {
          var next = eventQueue.shift();
          setTimeout(function () {
            showPopup(next);
          }, 500);
        }
      }, 300);
    }

    closeBtn.addEventListener('click', function () {
      clearTimeout(dismissTimer);
      hidePopup();
    });

    function shouldShowEvent(event) {
      if (!productId) return true;
      if (!event.productId) return true;
      return String(event.productId) === String(productId);
    }

    function handleFomoEvent(event) {
      if (!shouldShowEvent(event)) return;
      showPopup(event);
    }

    function connectSocket() {
      if (typeof io === 'undefined') {
        startPolling();
        return;
      }

      try {
        socket = io(appUrl, {
          path: '/socket.io/',
          query: { shopDomain: shopDomain },
          transports: ['websocket', 'polling'],
          reconnection: true,
          reconnectionAttempts: 5,
          reconnectionDelay: 1000,
          reconnectionDelayMax: 16000
        });

        socket.on('connect', function () {
          usePolling = false;
          stopPolling();
        });

        socket.on('fomo:purchase', function (event) {
          handleFomoEvent(event);
        });

        socket.on('connect_error', function () {
          if (!usePolling) {
            usePolling = true;
            startPolling();
          }
        });

        socket.on('disconnect', function (reason) {
          if (reason === 'io server disconnect' || reason === 'io client disconnect') {
            usePolling = true;
            startPolling();
          }
        });

        socket.io.on('reconnect_failed', function () {
          usePolling = true;
          startPolling();
        });
      } catch (e) {
        startPolling();
      }
    }

    function startPolling() {
      if (pollInterval) return;

      fetchFomoData();
      pollInterval = setInterval(fetchFomoData, 30000);
    }

    function stopPolling() {
      if (pollInterval) {
        clearInterval(pollInterval);
        pollInterval = null;
      }
      stopHistoricalCycle();
    }

    function fetchFomoData() {
      var url = appUrl + '/api/fomo?shopDomain=' + encodeURIComponent(shopDomain);
      if (productId) {
        url += '&productId=' + encodeURIComponent(productId);
      }

      fetch(url)
        .then(function (res) {
          if (!res.ok) throw new Error('HTTP ' + res.status);
          return res.json();
        })
        .then(function (data) {
          if (data.settings) {
            if (data.settings.popupPosition) settings.popupPosition = data.settings.popupPosition;
            if (data.settings.displayDuration) settings.displayDuration = data.settings.displayDuration;
            if (typeof data.settings.showHistoricalOrders !== 'undefined') {
              settings.showHistoricalOrders = data.settings.showHistoricalOrders;
            }
            if (data.settings.historicalInterval) settings.historicalInterval = data.settings.historicalInterval;
            applyPosition();
          }

          var orders = data.events || data.orders || [];
          if (orders.length > 0 && settings.showHistoricalOrders) {
            historicalOrders = orders;
            historicalIndex = 0;
            startHistoricalCycle();
          }
        })
        .catch(function () {
          // Silently fail — will retry on next poll interval
        });
    }

    function startHistoricalCycle() {
      stopHistoricalCycle();
      if (historicalOrders.length === 0) return;

      showNextHistorical();
      historicalTimer = setInterval(function () {
        showNextHistorical();
      }, settings.historicalInterval * 1000);
    }

    function stopHistoricalCycle() {
      if (historicalTimer) {
        clearInterval(historicalTimer);
        historicalTimer = null;
      }
    }

    function showNextHistorical() {
      if (historicalOrders.length === 0) return;

      var order = historicalOrders[historicalIndex];
      historicalIndex = (historicalIndex + 1) % historicalOrders.length;

      if (shouldShowEvent(order)) {
        showPopup(order);
      }
    }

    // Load Socket.IO then initialize
    var socketScript = document.createElement('script');
    socketScript.src = 'https://cdn.socket.io/4.7.5/socket.io.min.js';
    socketScript.crossOrigin = 'anonymous';
    socketScript.onload = connectSocket;
    socketScript.onerror = startPolling;
    document.head.appendChild(socketScript);
  })();
</script>

{% schema %}
{
  "name": "Social Proof Popups",
  "target": "head",
  "settings": [
    {
      "type": "text",
      "id": "app_url",
      "label": "App URL",
      "info": "The URL of your Nexify app (e.g., https://your-app.com)",
      "default": "https://thenexify.app"
    }
  ]
}
{% endschema %}
