{% comment %}
  Upsell Offers - Shopify Theme App Extension
  Requirements: 6.2, 6.3, 6.4, 6.6, 6.7

  Displays upsell offers based on placement type:
  - post_purchase / thank_you: Centered card on thank-you page
  - cart: Sticky bar at bottom of page
  - product_page: Inline card on product page
{% endcomment %}

<div
  id="nexify-upsell-widget"
  data-shop-id="{{ shop.id }}"
  data-placement="{{ block.settings.placement_type }}"
  data-app-url="{{ block.settings.app_url }}"
  data-product-id="{{ product.id | default: '' }}"
  style="display: none;"
>
  <!-- Post-purchase / Thank-you card layout -->
  <div id="nexify-upsell-card" class="nexify-upsell-card" style="display: none;">
    <div class="nexify-upsell-card__inner">
      <h3 class="nexify-upsell-card__title" id="nexify-upsell-title"></h3>
      <div class="nexify-upsell-card__product">
        <p class="nexify-upsell-card__product-name" id="nexify-upsell-product"></p>
        <p class="nexify-upsell-card__discount" id="nexify-upsell-discount" style="display: none;"></p>
      </div>
      <button class="nexify-upsell-card__cta" id="nexify-upsell-accept">
        Add to Order
      </button>
      <button class="nexify-upsell-card__dismiss" id="nexify-upsell-dismiss">
        No thanks
      </button>
    </div>
  </div>

  <!-- Cart sticky bar layout -->
  <div id="nexify-upsell-bar" class="nexify-upsell-bar" style="display: none;">
    <div class="nexify-upsell-bar__inner">
      <span class="nexify-upsell-bar__title" id="nexify-upsell-bar-title"></span>
      <span class="nexify-upsell-bar__discount" id="nexify-upsell-bar-discount"></span>
      <button class="nexify-upsell-bar__cta" id="nexify-upsell-bar-accept">
        Add to Cart
      </button>
      <button class="nexify-upsell-bar__close" id="nexify-upsell-bar-close">&times;</button>
    </div>
  </div>
</div>

<style>
  .nexify-upsell-card {
    max-width: 480px;
    margin: 24px auto;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  .nexify-upsell-card__inner {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 24px;
    text-align: center;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  .nexify-upsell-card__title {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 12px 0;
    color: #111827;
  }

  .nexify-upsell-card__product-name {
    font-size: 16px;
    color: #374151;
    margin: 0 0 8px 0;
  }

  .nexify-upsell-card__discount {
    font-size: 14px;
    color: #059669;
    font-weight: 600;
    margin: 0 0 16px 0;
  }

  .nexify-upsell-card__cta {
    display: inline-block;
    padding: 12px 24px;
    background: #3b82f6;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    margin-right: 8px;
    transition: background 0.2s;
  }

  .nexify-upsell-card__cta:hover {
    background: #2563eb;
  }

  .nexify-upsell-card__dismiss {
    display: inline-block;
    padding: 12px 24px;
    background: transparent;
    color: #6b7280;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    font-size: 14px;
    cursor: pointer;
    transition: background 0.2s;
  }

  .nexify-upsell-card__dismiss:hover {
    background: #f3f4f6;
  }

  .nexify-upsell-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  .nexify-upsell-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 14px 24px;
    background: #1f2937;
    color: #ffffff;
    box-shadow: 0 -4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  .nexify-upsell-bar__title {
    font-size: 14px;
    font-weight: 500;
  }

  .nexify-upsell-bar__discount {
    font-size: 14px;
    font-weight: 700;
    color: #34d399;
  }

  .nexify-upsell-bar__cta {
    padding: 8px 16px;
    background: #3b82f6;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }

  .nexify-upsell-bar__cta:hover {
    background: #2563eb;
  }

  .nexify-upsell-bar__close {
    background: transparent;
    border: none;
    color: #9ca3af;
    font-size: 20px;
    cursor: pointer;
    padding: 4px 8px;
    line-height: 1;
  }

  .nexify-upsell-bar__close:hover {
    color: #ffffff;
  }
</style>

{{ 'upsell-widget.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Upsell Offers",
  "target": "section",
  "settings": [
    {
      "type": "select",
      "id": "placement_type",
      "label": "Placement Type",
      "options": [
        { "value": "post_purchase", "label": "Post Purchase" },
        { "value": "cart", "label": "Cart (Sticky Bar)" },
        { "value": "product_page", "label": "Product Page" },
        { "value": "thank_you", "label": "Thank You Page" }
      ],
      "default": "cart"
    },
    {
      "type": "text",
      "id": "app_url",
      "label": "App URL",
      "default": "https://your-app-url.com"
    }
  ]
}
{% endschema %}
