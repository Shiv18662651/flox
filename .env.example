# Shopify App Configuration
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_APP_URL=https://your-app-url.com
SCOPES=read_products,write_products,read_orders,write_orders,read_customers,write_customers,read_checkouts,write_checkouts,read_discounts,write_discounts,read_script_tags,write_script_tags

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/nexify?schema=public

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Meilisearch
MEILISEARCH_URL=http://127.0.0.1:7700
MEILISEARCH_MASTER_KEY=your_meilisearch_master_key

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_URL=https://your-r2-public-url.com

# Brevo (Email)
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Your Store Name

# Groq AI (used for SEO meta generation and review sentiment analysis)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama3-70b-8192

# Sentry (Error Monitoring)
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# Session
SESSION_SECRET=your_session_secret_at_least_32_characters_long

# Application
NODE_ENV=development
PORT=3000
